      ],
      "actions": [
        {
          "type": "ChangeMap",
          "targetEventId": "",
          "delayMs": 0,
          "payloadJson": "{\"map\":\"res://CoreEngine/Maps/DiceRoom.tscn\"}"
        }
      ],
      "notes": "对白结束后切入起始地图"
