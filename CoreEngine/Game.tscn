[sub_resource type="GDScript" id="GDScript_lpbfn"]
resource_name = "CollectionGrid"
script/source = "# This element displays a grid of all collectibles (orbs and map), divided into areas.
# See also CollectibleGridItem.tscn. An item is visible in the grid if it was collected.
extends PanelContainer

func _input(event: InputEvent) -> void:
	if event is InputEventKey:
		if event.pressed:
			# Toggle visibility when pressing M.
			if event.keycode == KEY_M:
				visible = not visible
				# If visible, update collection grid items.
				if visible:
					propagate_call(&\"update_collectible\")
"

