[sub_resource type="GDScript" id="GDScript_bxd4l"]
script/source = "# Simple elevator script. This scene exists in ElevatorRoom.tscn and UpperElevatorRoom.tscn.
# It's not really related to MetSys, but it's quite intricate. The elvator moves when pressing W,
# Freezing player's controls. After going out of the screen, map changes and the elevator in the
# new room is activated.
extends StaticBody2D

const ActorFramework = preload(\"res://CoreEngine/Scripts/Actor/ActorFramework.gd\")

# Whether the elevator should go up or down.
@export var up := true
# Map to teleport to after reaching the target.
@export_file(\"room_link\") var target_map: String
# Initial position of the elevator.
@onready var start_y := position.y

var moving: int
var player: Node2D
var passengers: Array[Node2D] = []

func _physics_process(delta: float) -> void:
	if moving:
		position.y += 200 * delta * signf(moving)
		for p in passengers:
			if is_instance_valid(p):
				p.position.y += 200 * delta * signf(moving)
		
		# Detect when the elevator goes out of the screen and teleport appropriately.
		if moving == -1 and position.y < -64:
			var workbench := WorkbenchService.get_singleton()
			if workbench:
				var payload := Dictionary()
				payload[\"type\"] = ActorFramework.TYPE_LOAD_ROOM_REQUEST
				payload[\"target_map\"] = target_map
				var after := Dictionary()
				after[\"action\"] = StringName(\"call_map_node_method\")
				after[\"node\"] = StringName(\"Elevator\")
				after[\"method\"] = StringName(\"enter\")
				payload[\"after\"] = after
				workbench.send(payload)
			moving = 0
			return
		elif moving == -2 and position.y < start_y:
			position.y = start_y
			if is_instance_valid(player):
				player.event = false
			passengers.clear()
			moving = 0
		elif moving == 1 and position.y > MetSys.current_room.get_size().y:
			var workbench := WorkbenchService.get_singleton()
			if workbench:
				var payload := Dictionary()
				payload[\"type\"] = ActorFramework.TYPE_LOAD_ROOM_REQUEST
				payload[\"target_map\"] = target_map
				var after := Dictionary()
				after[\"action\"] = StringName(\"call_map_node_method\")
				after[\"node\"] = StringName(\"Elevator\")
				after[\"method\"] = StringName(\"enter\")
				payload[\"after\"] = after
				workbench.send(payload)
			moving = 0
			return
		elif moving == 2 and position.y > start_y:
			position.y = start_y
			if is_instance_valid(player):
				player.event = false
			passengers.clear()
			moving = 0
		
		return
	
	var bodies: Array[Node2D] = $Area2D.get_overlapping_bodies()
	var has_player := false
	for b in bodies:
		if b.is_in_group(&\"player\"):
			has_player = true
			break
	if has_player:
		$Label.show()
	else:
		$Label.hide()
		return
	
	if Input.is_action_just_pressed(\"elevator_up\"):
		moving = -1 if up else 1
		player = null
		passengers.clear()
		for b in bodies:
			var n := b as Node2D
			if n == null:
				continue
			if b.is_in_group(&\"player\") and player == null:
				player = n
			if b is CharacterBody2D:
				passengers.append(n)
		if player == null:
			moving = 0
			passengers.clear()
			return
		player.event = true
		$Label.hide()

# Called after being transported to the target room.
func enter():
	# Set initial position of the elevator.
	if up:
		position.y = -64
		moving = 2
	else:
		position.y = MetSys.get_current_room_instance().get_size().y + 64
		moving = -2
	# Put the player at the elevator.
	var workbench := WorkbenchService.get_singleton()
	if workbench == null:
		return
	player = workbench.get_service(StringName(\"player\")) as Node2D
	if player == null:
		return
	player.position.y = position.y - 64
	passengers.clear()
	passengers.append(player)
"

